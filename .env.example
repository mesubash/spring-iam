# Spring IAM environment configuration
# Copy to .env and replace values for local/dev usage

# --- Database ---
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=iam_db

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Security ---
# Internal API key for service-to-service calls
IAM_INTERNAL_API_KEY=change-me-internal-key

# JWT settings for admin access
# HS256 secret (must be at least 32 chars)
IAM_JWT_SECRET=change-me-jwt-secret-32chars-minimum
IAM_JWT_ISSUER=iam-service
IAM_JWT_AUDIENCE=iam-admin

# --- Audit retention ---
IAM_AUDIT_RETENTION_MONTHS=24
IAM_AUDIT_RETENTION_ACTION=DROP

# --- Audit partitioning ---
IAM_AUDIT_PARTITIONING_ENABLED=true
IAM_AUDIT_PARTITIONING_CREATE_AHEAD_MONTHS=2
IAM_AUDIT_PARTITIONING_TIMEZONE=UTC
IAM_AUDIT_PARTITIONING_CRON=0 15 0 * * *
IAM_AUDIT_RETENTION_CRON=0 30 1 * * *

# --- App ---
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=local
