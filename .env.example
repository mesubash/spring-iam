# ============================================================================
# HGN IAM Service — Environment Configuration
# ============================================================================
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# docker-compose reads this file via env_file, so every variable here is
# injected directly into the iam-service container.
# DB_HOST and REDIS_HOST are overridden in docker-compose.yml to use the
# Docker network container names (postgres / redis) instead of localhost.
# ============================================================================

# ── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=iam_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ── JPA ──────────────────────────────────────────────────────────────────────
# none  = Flyway manages schema (default, recommended)
# validate = Hibernate validates schema against entities (useful in CI)
JPA_DDL_AUTO=none

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Service-to-Service Security ───────────────────────────────────────────────
# Sent in X-Internal-Api-Key header by downstream services calling AuthZ APIs
IAM_INTERNAL_API_KEY=CHANGE_ME

# Service JWT — signs inter-service tokens (HS256, min 32 chars)
# Generate: openssl rand -hex 32
IAM_JWT_SECRET=CHANGE_ME_min_32_chars
IAM_JWT_ISSUER=iam-service
IAM_JWT_AUDIENCE=iam-admin

# ── User JWT (AuthN — access & refresh tokens issued on login) ────────────────
# Must be DIFFERENT from IAM_JWT_SECRET. Min 32 chars.
# Generate: openssl rand -hex 32
APP_JWT_SECRET=CHANGE_ME_different_from_above_min_32_chars

# ── Cookie Settings ───────────────────────────────────────────────────────────
# Encrypt the refresh token stored in the HTTP-only __Host-Session-Id cookie
APP_JWT_ENCRYPT_COOKIES=false
# Domain for the cookie — leave blank for localhost, set to e.g. hgn.com in prod
APP_COOKIE_DOMAIN=
# Set to true in production (requires HTTPS)
APP_COOKIE_SECURE=false

# ── Frontend / CORS ───────────────────────────────────────────────────────────
APP_FRONTEND_URL=http://localhost:3000
# Comma-separated whitelist of allowed OAuth2 post-login redirect URLs
APP_ALLOWED_REDIRECT_URIS=http://localhost:3000/oauth/callback
# Comma-separated origins allowed by CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Google OAuth2 ─────────────────────────────────────────────────────────────
# Obtain from: https://console.cloud.google.com → APIs & Services → Credentials
# Create an OAuth 2.0 Client ID (Web application).
# Add authorized redirect URI: http://localhost:8080/login/oauth2/code/google
#
# IMPORTANT: Both values MUST be non-empty strings or the app will refuse to
# start (Spring Security validates this at boot time).
# If you don't have Google credentials yet, set them to any non-empty string
# (e.g. CHANGE_ME). Password-based login will still work; only Google SSO
# will fail at runtime when a user actually tries to sign in with Google.
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME

# ── Audit Partitioning ────────────────────────────────────────────────────────
IAM_AUDIT_PARTITIONING_ENABLED=true
IAM_AUDIT_PARTITIONING_CREATE_AHEAD_MONTHS=2
IAM_AUDIT_PARTITIONING_TIMEZONE=UTC
# Cron: create next month's partition at 00:15 every day
IAM_AUDIT_PARTITIONING_CRON=0 15 0 * * *

# ── Audit Retention ───────────────────────────────────────────────────────────
IAM_AUDIT_RETENTION_MONTHS=24
# DROP = delete old partitions  |  ARCHIVE = move to archive table
IAM_AUDIT_RETENTION_ACTION=DROP
# Cron: run retention job at 01:30 every day
IAM_AUDIT_RETENTION_CRON=0 30 1 * * *

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=local
