# ============================================================================
# Spring IAM — Environment Configuration
# ============================================================================
# Copy to .env and fill in your values:  cp .env.example .env
#
# docker-compose reads this file via env_file. DB_HOST and REDIS_HOST are
# overridden in docker-compose.yml to the container names (postgres / redis).
# See docs/CONFIGURATION.md for the full reference.
# ============================================================================

# ── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=iam_db
DB_USERNAME=postgres
DB_PASSWORD=postgres
# none = Flyway owns the schema (recommended) | validate = check entities in CI
JPA_DDL_AUTO=none

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Signing & cookie keys (AuthN) ────────────────────────────────────────────
# Access tokens are RS256, signed with keys auto-generated into the signing_keys
# table on first start — there is NO signing secret to set.
#
# Encrypts the signing private keys at rest. SET THIS IN PRODUCTION.
# Generate: openssl rand -hex 32
IAM_KEY_ENCRYPTION_KEY=
# Independent key for refresh-cookie encryption (falls back to APP_JWT_SECRET).
# Generate: openssl rand -hex 32
IAM_COOKIE_KEY=
# Legacy secret — only feeds the cookie-key fallback above. Any non-empty value.
APP_JWT_SECRET=CHANGE_ME_min_32_chars
# How much authz data rides in the access token: minimal | roles | permissions
APP_JWT_CLAIMS_MODE=roles

# ── Service-to-service security (AuthZ) ──────────────────────────────────────
# Sent as X-Internal-Api-Key by services calling the PDP. Empty disables it.
# (Or enable iam.features.service-registry for per-service keys instead.)
IAM_INTERNAL_API_KEY=CHANGE_ME
# Optional inter-service JWT verification
IAM_JWT_SECRET=
IAM_JWT_ISSUER=iam-service
IAM_JWT_AUDIENCE=iam-admin

# ── Cookies / frontend / CORS ────────────────────────────────────────────────
# __Host-Refresh cookies REQUIRE Secure — keep true behind HTTPS; set false only
# for plain-HTTP local dev (and rename the cookie).
APP_COOKIE_SECURE=true
APP_COOKIE_DOMAIN=
APP_JWT_ENCRYPT_COOKIES=true
APP_FRONTEND_URL=http://localhost:3000
# OAuth redirect allowlist (empty ⇒ frontend origin only)
APP_ALLOWED_REDIRECT_URIS=
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Google OAuth2 (optional) ─────────────────────────────────────────────────
# Social login is OFF by default (iam.features.oauth2=false) and no registration
# is required to boot. To enable: set iam.features.oauth2=true in application.yml
# (or IAM_FEATURES_OAUTH2=true) AND provide these — Google's endpoints are built
# in, so only the client id/secret are needed:
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_ID=
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_SECRET=

# ── Optional features ────────────────────────────────────────────────────────
# Alert POST fired when a break-glass grant is created (empty = disabled)
IAM_BREAK_GLASS_WEBHOOK=

# ── Audit partitioning & retention ───────────────────────────────────────────
IAM_AUDIT_PARTITIONING_ENABLED=true
IAM_AUDIT_PARTITIONING_CREATE_AHEAD_MONTHS=2
IAM_AUDIT_PARTITIONING_TIMEZONE=UTC
IAM_AUDIT_PARTITIONING_CRON=0 15 0 * * *
IAM_AUDIT_RETENTION_MONTHS=24
IAM_AUDIT_RETENTION_ACTION=DROP
IAM_AUDIT_RETENTION_CRON=0 30 1 * * *

# ── Server ───────────────────────────────────────────────────────────────────
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=local
